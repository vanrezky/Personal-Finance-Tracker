{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "source": "/feedback/((?!general).*)",
  "destination": "/api/feedback/general"
  "rewrites": [
    {
      "source": "/(.*\\.(ico|png|jpg|jpeg|svg|css|js|json|webmanifest))",
      "destination": "/$1"
    },
    {
      "source": "/(sw.js)",
      "destination": "/sw.js"
    },
    {
      "source": "/(workbox-.*\\.js)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
