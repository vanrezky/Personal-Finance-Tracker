rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
             request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'members', 'createdAt', 'ownerUid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.members is list && data.members.size() > 0 && data.members.size() <= 20 &&
             data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 50 &&
             data.ownerUid is string && data.ownerUid.size() > 0 && data.ownerUid.size() <= 100 &&
             (!('payday' in data) || (data.payday is int && data.payday >= 1 && data.payday <= 31));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['householdId', 'type', 'amount', 'category', 'date', 'createdAt', 'authorUid']) &&
             data.householdId is string && data.householdId.size() > 0 && data.householdId.size() <= 100 &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.date is string && data.date.size() > 0 && data.date.size() <= 50 &&
             data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 50 &&
             data.authorUid is string && data.authorUid.size() > 0 && data.authorUid.size() <= 100 &&
             (!('note' in data) || (data.note is string && data.note.size() <= 1000)) &&
             (!('authorName' in data) || (data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 200)) &&
             (!('receiptImage' in data) || (data.receiptImage is string && data.receiptImage.size() <= 1000000));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 100 &&
             (!('email' in data) || (data.email is string && data.email.size() > 0 && data.email.size() <= 200)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 200)) &&
             (!('authProvider' in data) || data.authProvider in ['google', 'password']) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() <= 50)) &&
             (!('currentHouseholdId' in data) || (data.currentHouseholdId is string && data.currentHouseholdId.size() > 0 && data.currentHouseholdId.size() <= 100));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == userId;
      allow delete: if false;
    }

    match /households/{householdId} {
      allow get: if isAuthenticated();
      allow list: if false;

      allow create: if isAuthenticated() &&
                    isValidHousehold(request.resource.data) &&
                    request.auth.uid in request.resource.data.members &&
                    request.resource.data.ownerUid == request.auth.uid;

      allow update: if isAuthenticated() &&
                    isValidHousehold(request.resource.data) &&
                    request.resource.data.ownerUid == resource.data.ownerUid &&
                    (
                      request.resource.data.payday == resource.data.payday ||
                      request.auth.uid == resource.data.ownerUid
                    ) &&
                    (
                      request.auth.uid in resource.data.members ||
                      (request.resource.data.members.hasAll(resource.data.members) &&
                       request.resource.data.members.size() == resource.data.members.size() + 1 &&
                       request.auth.uid in request.resource.data.members)
                    );
      allow delete: if false;

      match /transactions/{transactionId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId) &&
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.householdId == householdId &&
                      request.resource.data.authorUid == request.auth.uid;
        allow update: if isHouseholdMember(householdId) &&
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.householdId == householdId &&
                      request.resource.data.authorUid == resource.data.authorUid &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isHouseholdMember(householdId);
      }

      match /categories/{categoryId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId) &&
                      request.resource.data.keys().hasAll(['name', 'type', 'createdAt', 'authorUid']) &&
                      request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100 &&
                      request.resource.data.type in ['income', 'expense'] &&
                      request.resource.data.createdAt is string && request.resource.data.createdAt.size() > 0 && request.resource.data.createdAt.size() <= 50 &&
                      request.resource.data.authorUid == request.auth.uid;
        allow update: if isHouseholdMember(householdId) &&
                      request.resource.data.keys().hasAll(['name', 'type', 'createdAt', 'authorUid']) &&
                      request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100 &&
                      request.resource.data.type == resource.data.type &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.authorUid == resource.data.authorUid;
        allow delete: if isHouseholdMember(householdId);
      }
    }
  }
}
